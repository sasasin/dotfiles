[user]
	name = ShinnosukeSuzuki
	email = sasasin@sasasin.net
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[ghq]
    root = ~/src
[core]
	editor = micro
	pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true          # n/N で diff セクションを移動（超便利）
    side-by-side = true      # 好みで false に変更可（1カラム表示）
    dark = true              # または light / omit（自動判別）
    line-numbers = true      # 行番号表示（好み）
[diff "sopsdiffer"]
        textconv = sops -d
